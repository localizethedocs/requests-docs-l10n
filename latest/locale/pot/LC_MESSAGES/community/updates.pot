"Fix error when urllib3 is unbundled and requests continues to use the "
"vendored import location."
msgstr ""

#: ../../../../HISTORY.md:1133
msgid "Include fixes to `urllib3`'s header handling."
msgstr ""

#: ../../../../HISTORY.md:1134
msgid "Requests' handling of unvendored dependencies is now more restrictive."
msgstr ""

