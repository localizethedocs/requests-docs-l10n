#: ../../../api.rst:109
msgid "Status Code Lookup"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/requests/status_codes.py:docstring
#: of requests.status_codes:1
msgid ""
"The ``codes`` object defines a mapping from common names for HTTP statuses "
"to their numerical codes, accessible either as attributes or as dictionary "
"items."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/requests/status_codes.py:docstring
#: of requests.status_codes:5
msgid "Example::"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/requests/status_codes.py:docstring
#: of requests.status_codes:7
msgid ""
">>> import requests\n"
">>> requests.codes['temporary_redirect']\n"
"307\n"
">>> requests.codes.teapot\n"
"418\n"
">>> requests.codes['\\o/']\n"
"200"
